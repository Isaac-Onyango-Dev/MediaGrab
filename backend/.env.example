# MediaGrab Backend – Environment Variables
# Copy this file to .env and customize

# Server
MEDIAGRAB_HOST=0.0.0.0
MEDIAGRAB_PORT=8000

# Output directory (where files are saved on the server machine)
MEDIAGRAB_OUTPUT_DIR=~/Downloads/MediaGrab

# CORS origins (comma-separated, or * for all)
# For LAN use, keep as * or set your device IPs
MEDIAGRAB_CORS_ORIGINS=["*"]

# Max concurrent downloads
MEDIAGRAB_MAX_CONCURRENT_DOWNLOADS=3

# Logging
MEDIAGRAB_LOG_LEVEL=info
MEDIAGRAB_DEBUG=false

# Optional API Key (set to require authentication on all endpoints)
# Leave empty to disable authentication (default for LAN use)
# MEDIAGRAB_API_KEY=your-secret-key-here

# ================================================
# Donation Payment Settings (Optional)
# ================================================

# Flutterwave (Africa) - Get keys from https://dashboard.flutterwave.com
# MEDIAGRAB_FLW_SECRET_KEY=your_flutterwave_secret_key
# MEDIAGRAB_FLW_PUBLIC_KEY=your_flutterwave_public_key
# MEDIAGRAB_FLW_SECRET_HASH=your_flutterwave_secret_hash

# Stripe (Global) - Get key from https://dashboard.stripe.com
# MEDIAGRAB_STRIPE_SECRET_KEY=your_stripe_secret_key

# PayPal - Get credentials from https://developer.paypal.com
# MEDIAGRAB_PAYPAL_CLIENT_ID=your_paypal_client_id
# MEDIAGRAB_PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# NOWPayments (Crypto 150+ coins) - Get API key from https://nowpayments.io
# MEDIAGRAB_NOWPAYMENTS_API_KEY=your_nowpayments_api_key
# MEDIAGRAB_NOWPAYMENTS_IPN_SECRET=your_ipn_secret

# Coinbase Commerce - Get key from https://commerce.coinbase.com
# MEDIAGRAB_COINBASE_COMMERCE_API_KEY=your_coinbase_key

# Direct Wallet Addresses (for crypto donations without API)
# MEDIAGRAB_WALLET_BTC=bc1q...
# MEDIAGRAB_WALLET_ETH=0x...
# MEDIAGRAB_WALLET_SOL=...
# MEDIAGRAB_WALLET_USDC=...
# MEDIAGRAB_WALLET_USDT=...

# Donation Settings
# MEDIAGRAB_DONATION_DEFAULT_CURRENCY=KES
# MEDIAGRAB_DONATION_CAMPAIGN_ID=mediagrab
# MEDIAGRAB_DONATION_MERCHANT_NAME="MediaGrab"
# MEDIAGRAB_DONATION_REDIRECT_SUCCESS=https://yoursite.com/success
# MEDIAGRAB_DONATION_REDIRECT_CANCEL=https://yoursite.com/cancel
# MEDIAGRAB_DONATION_CRYPTO_ENABLED=true
